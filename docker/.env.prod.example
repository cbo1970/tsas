# Production environment variables for compose.prod.yml (TEN-58).
# Copy to `.env` next to docker/compose.yml and fill in real values.
# Treat this file as a SECRET — never commit the populated `.env`.

# ---- Application database (used by the Spring Boot backend) -----------------
DB_NAME=tsas
DB_USERNAME=tsas_app
DB_PASSWORD=__CHANGE_ME__strong_random_pw

# ---- Keycloak backing store (separate DB on the same postgres instance) -----
KC_DB_NAME=keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=__CHANGE_ME__strong_random_pw

# ---- Keycloak bootstrap admin (used only on first start; rotate immediately) -
KC_ADMIN_USERNAME=__CHANGE_ME__admin_username
KC_ADMIN_PASSWORD=__CHANGE_ME__strong_random_pw

# ---- Keycloak public hostname (must match the TLS cert SAN) -----------------
KC_HOSTNAME=auth.tsas.example.com

# ---- Issuer URI as seen by the backend (Spring Security validator) ----------
KEYCLOAK_ISSUER_URI=https://auth.tsas.example.com/realms/tsas

# ---- SMTP (e.g. Sendgrid) ---------------------------------------------------
KC_SMTP_HOST=smtp.sendgrid.net
KC_SMTP_PORT=587
KC_SMTP_FROM=no-reply@tsas.example.com
KC_SMTP_STARTTLS=true
KC_SMTP_AUTH=true
KC_SMTP_USER=apikey
KC_SMTP_PASSWORD=__CHANGE_ME__sendgrid_api_key

# ---- OpenAI ----------------------------------------------------------------
OPENAI_API_KEY=__CHANGE_ME__sk-...

# ---- TLS certificate directory ---------------------------------------------
# Must contain tls.crt + tls.key (e.g. from Let's Encrypt's fullchain.pem + privkey.pem).
TLS_CERT_DIR=/etc/tsas/tls
